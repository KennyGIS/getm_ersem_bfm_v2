  # Build products
  build/
  tools/getm/build/
  local/
  *.o
  *.mod
  *.smod
  *.a
  *.so
  CMakeCache.txt
  CMakeFiles/
  cmake_install.cmake

  # Runtime data and output
  out/
  log/
  logs/
  model_out/
  restart/
  restart*/
  *.nc
  *.nc4
  *.cdf
  *.grib
  *.grb
  core.*
  *.stdout
  *.stderr

  # Temporary files
  *~
  *.swp
  *.swo

  # Model runtime outputs
  model_out/*
  !model_out/README.md
  !model_out/.gitkeep
  GETM_ERSEM_SETUPS/nwes/out/*
  !GETM_ERSEM_SETUPS/nwes/out/README.md
  !GETM_ERSEM_SETUPS/nwes/out/.gitkeep
  *.nc
  *.nc4
  restart*.in
  restart*.out
  *.log
